<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<fx:root
        type="VBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.entryeditor.aisummary.AiSummaryShowingView"
        spacing="10.0">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

    <BorderPane>
        <left>
            <CheckBox fx:id="markdownCheckbox" mnemonicParsing="false" text="Markdown"/>
        </left>
        <center>
            <Button mnemonicParsing="false" text="%Regenerate" onAction="#regenerate"/>
        </center>
    </BorderPane>

    <Text fx:id="summaryInfoText"
          textAlignment="CENTER"
          strokeType="OUTSIDE"
          strokeWidth="0.0"
          text="%Generated at %0 by %1 (algorithm %2)"/>
</fx:root>
