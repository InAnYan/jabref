<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.jabref.gui.icon.JabRefIconView?>
<?import org.jabref.gui.util.ListScrollPane?>
<fx:root
        type="VBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.chat.AiChatView">

    <ListScrollPane
            fx:id="chatHistoryScrollPane"
            VBox.vgrow="ALWAYS"/>

    <HBox spacing="10"
          alignment="BASELINE_CENTER">
        <Button fx:id="infoButton"
                onAction="#showInfo"
                styleClass="icon-button,narrow"
                textAlignment="CENTER">
            <graphic>
                <JabRefIconView
                        glyph="INTEGRITY_INFO"/>
            </graphic>
            <tooltip>
                <Tooltip
                        text="%View ingestion status"/>
            </tooltip>
        </Button>

        <TextField
                fx:id="userMessageTextField"
                HBox.hgrow="ALWAYS"/>

        <Button fx:id="sendButton"
                text="%Send"
                onAction="#send"/>
        <Button fx:id="retryButton"
                text="%Retry"
                onAction="#retry"/>
        <Button fx:id="cancelButton"
                text="%Cancel"
                onAction="#cancel"/>
    </HBox>

    <HBox spacing="10"
          alignment="BASELINE_CENTER">
        <Button alignment="CENTER"
                onAction="#clearChatHistory"
                styleClass="icon-button,narrow"
                textAlignment="CENTER">
            <graphic>
                <JabRefIconView
                        glyph="DELETE_ENTRY"/>
            </graphic>
            <tooltip>
                <Tooltip
                        text="%Clear chat history"/>
            </tooltip>
        </Button>

        <Label fx:id="noticeText"
               text="%Current AI model: %0. The AI may generate inaccurate or inappropriate responses. Please verify any information provided."
               HBox.hgrow="ALWAYS"/>
    </HBox>

</fx:root>
