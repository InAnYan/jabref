<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import org.jabref.gui.ai.chat.AiChatView?>
<?import org.jabref.gui.ai.statuspane.UniversalStatusPaneView?>
<?import org.jabref.gui.ai.AiPrivacyNoticeView?>
<fx:root
        type="StackPane"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.chat.AiEntryChatView">

    <AiPrivacyNoticeView
            fx:id="privacyNotice"/>

    <UniversalStatusPaneView
            fx:id="emptyDatabasePathPane"
            title="Unable to chat"
            description="Please save the library in order to chat."/>

    <UniversalStatusPaneView
            fx:id="emptyCitationKeyPane"
            title="Unable to chat"
            description="Please provide a non-empty citation key for this entry."/>

    <UniversalStatusPaneView
            fx:id="nonUniqueCitationKeyPane"
            title="Unable to chat"
            description="Please provide a unique citation key for this entry."/>

    <AiChatView
            fx:id="aiChatView"/>

</fx:root>
