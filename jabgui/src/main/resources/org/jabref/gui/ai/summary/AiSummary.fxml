<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.jabref.gui.ai.AiPrivacyNoticeView?>
<?import org.jabref.gui.ai.statuspane.ErrorStatusPaneView?>
<?import org.jabref.gui.ai.statuspane.LoadingStatusPaneView?>
<?import org.jabref.gui.ai.statuspane.SimpleStatusPaneView?>
<?import org.jabref.gui.ai.summary.AiSummaryShowingView?>
<fx:root
        type="StackPane"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.summary.AiSummaryView">
    <AiPrivacyNoticeView
            fx:id="privacyNotice"/>

    <BorderPane
            fx:id="pendingPane">
        <center>
            <VBox spacing="10.0"
                  alignment="CENTER">
                <padding>
                    <Insets top="10.0"
                            right="10.0"
                            bottom="10.0"
                            left="10.0"/>
                </padding>
                <Label text="%Ready to summarize">
                    <font>
                        <Font name="System Bold"
                              size="24.0"/>
                    </font>
                </Label>
                <HBox spacing="8.0"
                      alignment="CENTER">
                    <Label text="%Summarization algorithm:"/>
                    <ComboBox
                            fx:id="summarizatorCombo"
                            prefWidth="250.0"/>
                </HBox>
                <Button fx:id="generateButton"
                        text="%Generate"
                        onAction="#generate"/>
                <Label fx:id="pendingHint"
                       wrapText="true"/>
            </VBox>
        </center>
    </BorderPane>

    <LoadingStatusPaneView
            fx:id="processingPane"
            title="%Processing..."/>

    <ErrorStatusPaneView
            fx:id="errorPane"
            title="%Unable to generate summary"
            description="%Got error while processing the file:"
            restartButtonText="%Regenerate"
            cancelButtonText="%Cancel"
            onRestart="#regenerate"
            onCancel="#cancel"/>

    <SimpleStatusPaneView
            fx:id="noDatabasePathPane"
            title="%Unable to generate summary"
            description="%The path of the current library is not set, but it is required for summarization"/>

    <SimpleStatusPaneView
            fx:id="noCitationKeyPane"
            title="%Unable to generate summary"
            description="%Please provide a non-empty and unique citation key for this entry."/>

    <SimpleStatusPaneView
            fx:id="wrongCitationKeyPane"
            title="%Unable to generate summary"
            description="%Please provide a non-empty and unique citation key for this entry."/>

    <SimpleStatusPaneView
            fx:id="noFilesPane"
            title="%Unable to generate summary"
            description="%Please attach at least one PDF file to enable summarization of PDF file(s)."/>

    <SimpleStatusPaneView
            fx:id="noSupportedFileTypesPane"
            title="%Unable to generate summary"
            description="%Only PDF files are supported."/>

    <AiSummaryShowingView
            fx:id="summaryShowing"
            onRegenerate="#regenerate"
            onRegenerateCustom="#regenerateCustom"/>

</fx:root>
