<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import com.dlsc.unitfx.IntegerInputField?>
<?import org.controlsfx.control.textfield.CustomPasswordField?>
<fx:root
        type="VBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.chatmodelconfig.ChatModelConfigView"
        spacing="10.0">

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="%AI profile:"/>

        <ComboBox fx:id="profileComboBox"
                  HBox.hgrow="ALWAYS"/>

        <Button fx:id="renameProfileButton"
                text="%Rename"
                onAction="#onRenameProfile"/>

        <Button fx:id="deleteProfileButton"
                text="%Delete"
                onAction="#onDeleteProfile"/>

        <Button fx:id="addProfileButton"
                text="%Add"
                onAction="#onAddProfile"/>
    </HBox>

    <GridPane hgap="10"
              vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="LEFT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="%AI provider:"
               GridPane.rowIndex="0"
               GridPane.columnIndex="0"/>

        <ComboBox fx:id="providerComboBox"
                  HBox.hgrow="ALWAYS"
                  GridPane.rowIndex="0"
                  GridPane.columnIndex="1"/>

        <Label text="%Chat model:"
               GridPane.rowIndex="1"
               GridPane.columnIndex="0"/>

        <ComboBox fx:id="chatModelComboBox"
                  editable="true"
                  HBox.hgrow="ALWAYS"
                  GridPane.rowIndex="1"
                  GridPane.columnIndex="1"/>

        <Label text="%API key:"
               GridPane.rowIndex="2"
               GridPane.columnIndex="0"/>

        <CustomPasswordField fx:id="apiKeyTextField"
                             GridPane.rowIndex="2"
                             GridPane.columnIndex="1"/>

        <Label text="%API base URL"
               GridPane.rowIndex="3"
               GridPane.columnIndex="0"/>

        <TextField fx:id="apiBaseUrlTextField"
                   GridPane.rowIndex="3"
                   GridPane.columnIndex="1"/>

        <Label text="%Temperature:"
               GridPane.rowIndex="4"
               GridPane.columnIndex="0"/>

        <TextField fx:id="temperatureTextField"
                   GridPane.rowIndex="4"
                   GridPane.columnIndex="1"/>

        <Label text="%Context window size:"
               GridPane.rowIndex="5"
               GridPane.columnIndex="0"/>

        <IntegerInputField fx:id="contextWindowSizeTextField"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>

        <Label text="%Token estimator:"
               GridPane.rowIndex="6"
               GridPane.columnIndex="0"/>

        <ComboBox fx:id="tokenEstimatorComboBox"
                  HBox.hgrow="ALWAYS"
                  GridPane.rowIndex="6"
                  GridPane.columnIndex="1"/>
    </GridPane>
</fx:root>

