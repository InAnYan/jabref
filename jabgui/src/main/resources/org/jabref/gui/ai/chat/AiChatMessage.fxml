<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import org.jabref.gui.icon.JabRefIconView?>
<fx:root type="javafx.scene.layout.HBox"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         spacing="10"
         fx:controller="org.jabref.gui.ai.chat.AiChatMessageView">

    <VBox fx:id="vBox"
          maxWidth="Infinity">

        <Label fx:id="sourceLabel"
               style="-fx-font-weight: bold;"/>

        <Pane fx:id="markdownContentPane" />
    </VBox>

    <VBox fx:id="buttonsVBox" alignment="CENTER" spacing="5">
        <Button onAction="#onRegenerateClick" styleClass="icon-button,narrow">
            <graphic><JabRefIconView glyph="REFRESH"/></graphic>
        </Button>
        <Button onAction="#onDeleteClick" styleClass="icon-button,narrow">
            <graphic><JabRefIconView glyph="DELETE_ENTRY"/></graphic>
        </Button>
    </VBox>

</fx:root>
